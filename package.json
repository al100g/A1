{
  "name": "a1-music-app",
  "version": "1.0.0",
  "description": "A1 — AI-powered music and mood empowerment platform built with Next.js 15",
  "main": "index.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "postinstall": "prisma generate || true"
  },
  "prisma": {
    "seed": "ts-node --compiler-options '{\"module\":\"CommonJS\"}' prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.20.0",
    "next": "^15.2.9",
    "next-auth": "^5.1.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "stripe": "^17.7.0"
  },
  "devDependencies": {
    "@types/node": "^20.17.6",
    "@types/react": "^18.3.18",
    "eslint": "^8.57.0",
    "eslint-config-next": "^15.2.9",
    "jest": "^29.7.0",
    "prisma": "^5.20.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  }
}
