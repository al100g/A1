# .env.local.example
# This file is for LOCAL DEVELOPMENT only.
# Copy it to .env.local and fill in your values.
# .env.local is git-ignored and will never be committed.
# See docs/ENVIRONMENT_SETUP.md for instructions on each variable.

# ─────────────────────────────────────────────────────────────────────────────
# ENVIRONMENT
# ─────────────────────────────────────────────────────────────────────────────
NODE_ENV=development

# ─────────────────────────────────────────────────────────────────────────────
# NEXT.JS
# ─────────────────────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_TELEMETRY_DISABLED=1

# ─────────────────────────────────────────────────────────────────────────────
# NEXTAUTH SECRET (generate with: openssl rand -base64 32)
# ─────────────────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET=dev-secret-replace-in-production

# ─────────────────────────────────────────────────────────────────────────────
# GITHUB OAUTH
# Create at: https://github.com/settings/developers → OAuth Apps
# Callback URL: http://localhost:3000/api/auth/callback/github
# ─────────────────────────────────────────────────────────────────────────────
GITHUB_ID=your-github-oauth-client-id
GITHUB_SECRET=your-github-oauth-client-secret

# ─────────────────────────────────────────────────────────────────────────────
# DATABASE
# For local dev you can use: docker run -p 5432:5432 -e POSTGRES_PASSWORD=postgres postgres
# Or use a free cloud DB from Supabase/Neon/Railway.
# ─────────────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/a1_dev?schema=public

# ─────────────────────────────────────────────────────────────────────────────
# OPENAI (optional — app uses fallback prompts when not set)
# ─────────────────────────────────────────────────────────────────────────────
# OPENAI_API_KEY=sk-your-openai-api-key

# ─────────────────────────────────────────────────────────────────────────────
# REDIS (optional — caching disabled gracefully when not set)
# ─────────────────────────────────────────────────────────────────────────────
# REDIS_URL=redis://localhost:6379

# ─────────────────────────────────────────────────────────────────────────────
# STRIPE (optional for local dev unless testing payments)
# Use test keys from https://dashboard.stripe.com/test/apikeys
# ─────────────────────────────────────────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
# STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
# STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret
