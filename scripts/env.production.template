# =============================================================
# A1 Music App — Production Environment Template
# =============================================================
#
# INSTRUCTIONS:
#   1. Copy this file to a SECURE location (not your repo!)
#   2. Fill in all values marked with <REPLACE>
#   3. Add each variable to Vercel:
#      Vercel Dashboard → Project → Settings → Environment Variables
#
# ⚠️  SECURITY WARNING:
#   • NEVER commit this file with real values to version control
#   • NEVER share these values in chat, email, or Slack
#   • Rotate any secret that has been accidentally exposed
#   • Use different secrets for staging vs production
# =============================================================

# ─────────────────────────────────────────
# ENVIRONMENT
# ─────────────────────────────────────────
NODE_ENV=production

# ─────────────────────────────────────────
# APPLICATION URL
# ─────────────────────────────────────────
# Your Vercel deployment URL (or custom domain)
# Example: https://a1music.vercel.app  or  https://yourdomain.com
NEXTAUTH_URL=https://<YOUR_VERCEL_DOMAIN>.vercel.app
NEXT_PUBLIC_API_URL=https://<YOUR_VERCEL_DOMAIN>.vercel.app

# ─────────────────────────────────────────
# NEXTAUTH SECRET (REQUIRED)
# ─────────────────────────────────────────
# Generate with: openssl rand -hex 32
# Must be at least 32 random characters — NEVER reuse dev secret
NEXTAUTH_SECRET=<REPLACE_WITH_32_CHAR_RANDOM_STRING>

# ─────────────────────────────────────────
# GITHUB OAUTH (REQUIRED for login)
# ─────────────────────────────────────────
# Create at: https://github.com/settings/developers
# Callback URL must be: https://<YOUR_DOMAIN>/api/auth/callback/github
GITHUB_ID=<REPLACE_WITH_GITHUB_CLIENT_ID>
GITHUB_SECRET=<REPLACE_WITH_GITHUB_CLIENT_SECRET>

# ─────────────────────────────────────────
# OPENAI API (REQUIRED for AI features)
# ─────────────────────────────────────────
# Get from: https://platform.openai.com/account/api-keys
OPENAI_API_KEY=sk-<REPLACE_WITH_OPENAI_KEY>

# ─────────────────────────────────────────
# DATABASE (REQUIRED)
# ─────────────────────────────────────────
# Supabase:  postgresql://postgres:<PASSWORD>@db.<PROJECT_REF>.supabase.co:5432/postgres
# Railway:   postgresql://postgres:<PASSWORD>@<HOST>.railway.app:5432/railway
# Render:    postgresql://<USER>:<PASSWORD>@<HOST>/<DB_NAME>
DATABASE_URL=postgresql://<USER>:<PASSWORD>@<HOST>:<PORT>/<DATABASE>

# ─────────────────────────────────────────
# STRIPE (optional — for payments)
# ─────────────────────────────────────────
# Use sk_live_ / pk_live_ for production (NOT test keys)
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_<REPLACE_WITH_STRIPE_LIVE_SECRET>
STRIPE_PUBLISHABLE_KEY=pk_live_<REPLACE_WITH_STRIPE_LIVE_PUBLISHABLE>

# ─────────────────────────────────────────
# REDIS (optional — for caching)
# ─────────────────────────────────────────
# Upstash free tier: https://upstash.com
# Leave empty to disable caching
REDIS_URL=redis://default:<PASSWORD>@<HOST>:<PORT>
