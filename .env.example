# .env.example
# Copy this file to .env and fill in the values for your environment.
# Never commit your actual .env file to version control.

# Environment
# Set to 'development', 'staging', or 'production'
NODE_ENV=development

# Server
# Port for local development server
PORT=3000

# Stripe API Keys
# Get these from https://dashboard.stripe.com/apikeys
# Use sk_test_ / pk_test_ keys for development and staging.
# Use sk_live_ / pk_live_ keys for production.
STRIPE_SECRET_KEY=sk_test_
STRIPE_PUBLISHABLE_KEY=pk_test_

# Application
# Public-facing URL (NEXT_PUBLIC_ variables are accessible in the browser)
NEXT_PUBLIC_API_URL=https://your-app-url.vercel.app

# Database
# Format: postgresql://user:password@localhost:5432/dbname
# or use the connection string from your database provider
DATABASE_URL=postgresql://user:password@localhost:5432/dbname