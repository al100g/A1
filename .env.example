# .env.example
# ============================================================
# A1 Music App - Environment Variables
# ============================================================
# INSTRUCTIONS:
#   1. Copy this file:  cp .env.example .env.local
#   2. Fill in each value below
#   3. NEVER commit .env.local to version control
#
# Need help? See docs/ENV_SETUP.md for step-by-step instructions.
# ============================================================

# ─────────────────────────────────────────
# NODE ENVIRONMENT
# ─────────────────────────────────────────
# Set to 'development', 'staging', or 'production'
NODE_ENV=development

# ─────────────────────────────────────────
# APPLICATION URL
# ─────────────────────────────────────────
# Your app's public URL.
# Local development:  http://localhost:3000
# Production:         https://your-app.vercel.app
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000

# ─────────────────────────────────────────
# NEXTAUTH.JS (Authentication)
# ─────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Or run:        bash scripts/setup.sh
# Or visit:      https://generate-secret.vercel.app/32
NEXTAUTH_SECRET=your_nextauth_secret_here

# ─────────────────────────────────────────
# GITHUB OAUTH (Social Login)
# ─────────────────────────────────────────
# How to get these keys:
#   1. Go to https://github.com/settings/developers
#   2. Click "New OAuth App"
#   3. Homepage URL:             http://localhost:3000
#   4. Authorization callback:   http://localhost:3000/api/auth/callback/github
#   5. Copy Client ID → GITHUB_ID
#   6. Generate & copy Client Secret → GITHUB_SECRET
#
# Full guide: docs/GET_API_KEYS.md
GITHUB_ID=your_github_client_id
GITHUB_SECRET=your_github_client_secret

# ─────────────────────────────────────────
# OPENAI API (AI Songwriting & Mood)
# ─────────────────────────────────────────
# How to get this key:
#   1. Go to https://platform.openai.com/account/api-keys
#   2. Click "Create new secret key"
#   3. Copy it immediately — it won't show again!
#
# Full guide: docs/GET_API_KEYS.md
OPENAI_API_KEY=sk-your_openai_api_key_here

# ─────────────────────────────────────────
# DATABASE (PostgreSQL)
# ─────────────────────────────────────────
# Supabase (recommended):  postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres
# Railway:                 postgresql://postgres:[PASSWORD]@[HOST]:5432/railway
# Render:                  postgresql://[USER]:[PASSWORD]@[HOST]/[DBNAME]
#
# Full guide: docs/DATABASE_SETUP.md
DATABASE_URL=postgresql://user:password@localhost:5432/a1_music

# ─────────────────────────────────────────
# STRIPE (Payments — optional)
# ─────────────────────────────────────────
# How to get these keys:
#   1. Go to https://dashboard.stripe.com/apikeys
#   2. Use sk_test_ / pk_test_ for development
#   3. Use sk_live_ / pk_live_ for production
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# ─────────────────────────────────────────
# REDIS (Caching — optional)
# ─────────────────────────────────────────
# Upstash Redis (free tier): https://upstash.com
# Format: redis://default:[PASSWORD]@[HOST]:[PORT]
# Leave empty to disable caching
REDIS_URL=

# ─────────────────────────────────────────
# SERVER PORT (local development only)
# ─────────────────────────────────────────
PORT=3000